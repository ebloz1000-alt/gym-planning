{
  "version": 3,
  "plugins": [
    {
      "use": "vercel/vercel-plugin"
    }
  ],
  "builds": [
    {
      "src": "pubspec.yaml",
      "use": "@vercel/static-build"
    }
  ],
  "buildCommand": "flutter pub get && flutter build web --release",
  "outputDirectory": "build/web",
  "env": {
    "API_BASE_URL": "https://<YOUR_BACKEND_URL>"
  }
}
