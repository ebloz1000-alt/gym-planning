# Example environment variables for local development
# Copy this to .env and fill in real values before running the server.

# Django
DEBUG=True
SECRET_KEY=change-me
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (optional override)
# DATABASE_URL=sqlite:///db.sqlite3

# Daraja / Safaricom (Lipa Na M-Pesa Online / STK Push)
# Set DARAJA_ENV to 'sandbox' or 'production'
DARAJA_ENV=sandbox
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
# Public HTTPS callback URL that Safaricom will POST to. Must be reachable and use https://
# Example when using ngrok: https://abcd1234.ngrok.io/api/mpesa/callback/
DARAJA_CALLBACK_URL=

# Optional: override the default site URL used in emails/links
SITE_URL=http://localhost:8000
SECRET_KEY=change-me-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require

DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78abf3c0d5c5c7ed0
DARAJA_ENV=sandbox
DARAJA_CALLBACK_URL=https://<your-public-domain>/api/mpesa/callback/
